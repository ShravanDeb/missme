{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:full",
    "dev:web": "vite",
    "dev:api": "node --env-file-if-exists=.env.local local-api-server.mjs",
    "dev:api:vercel": "vercel dev --listen 3000",
    "dev:full": "concurrently -n WEB,API -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "concurrently": "^9.2.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vercel": "^43.0.0",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
}
